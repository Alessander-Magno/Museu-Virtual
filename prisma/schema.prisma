// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// npx prisma migrate dev - para alterações
// npx prisma migrate reset - para resetar
// npx prisma generate - regenera o client prisma

model Atracao {
  id                String    @id   @default(uuid())
  nome              String
  description       String
  disponibilidade   Boolean         @default(false)

  obras             Obra[]
}

model Obra {
  id                String   @id    @default(uuid())
  title             String
  description       String
  autor             String          @default("desconhecido")
  atracaoId         String
  
  atracao           Atracao @relation(fields: [atracaoId], references: [id])
}